{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "道场",
  "version": "1.0.0",
  "identifier": "com.digitaldojo.dojo",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "道场",
        "width": 460,
        "height": 780,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "decorations": true
      },
      {
        "label": "panel",
        "title": "道场面板",
        "url": "panel.html",
        "width": 280,
        "height": 200,
        "resizable": false,
        "fullscreen": false,
        "center": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "closable": false,
        "minimizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "title": "道场"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {}
}
