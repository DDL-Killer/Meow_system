[Unit]
Description=Digital Dojo · 数字道场 — FastAPI Backend
After=network.target

[Service]
Type=simple
User=meowzart
WorkingDirectory=/Users/meowzart/Desktop/喵系统
Environment="DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE"
Environment="PATH=/Users/meowzart/Desktop/喵系统/.venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/Users/meowzart/Desktop/喵系统/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
